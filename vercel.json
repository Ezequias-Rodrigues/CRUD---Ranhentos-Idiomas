{
    "version": 2,
    "buildCommand": "node vercel-build.js",
    "outputDirectory": "dist",
    "installCommand": "npm install",
    "devCommand": "npm run dev",
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "https://crud-ranhentos-idiomas.onrender.com/api/$1"
        },
        {
            "src": "/assets/(.*)",
            "dest": "/assets/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}
