{
    "version": 2,
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "installCommand": "npm install",
    "public": true,
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "https://crud-ranhentos-idiomas.onrender.com/api/$1"
        },
        {
            "src": "/(.*)\\.(js|css|map|json|png|jpg|jpeg|svg|ico|woff|woff2)$",
            "headers": {
                "Cache-Control": "public, max-age=31536000, immutable"
            },
            "continue": true
        },
        {
            "src": "/(.*)",
            "dest": "/index.html",
            "status": 200
        }
    ]
}
