{
    "version": 2,
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "installCommand": "npm install",
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "https://crud-ranhentos-idiomas.onrender.com/api/$1"
        },
        {
            "src": "/assets/(.*)\\.css",
            "headers": { "Content-Type": "text/css" },
            "dest": "/assets/$1.css"
        },
        {
            "src": "/assets/(.*)\\.js",
            "headers": { "Content-Type": "application/javascript" },
            "dest": "/assets/$1.js"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}
